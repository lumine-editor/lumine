; Install file: dependencies (the bundled packages under packages/) as real
; copies instead of symlinks. NOTE the inverted meaning: `true` means "install
; as a regular dependency" i.e. copy, NOT symlink; `false` (npm default) creates
; symlinks. Symlinks break the packaged build because require.resolve() reports
; the packages/ realpath, which does not exist in the packaged app — only the
; node_modules copy is bundled. Dev loads bundled packages straight from
; packages/, so the build-time copies never need to be live.
install-links=true
