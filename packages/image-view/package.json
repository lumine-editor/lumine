{
  "name": "image-view",
  "author": "lumine-code",
  "version": "1.0.0",
  "description": "Open images in an editor",
  "main": "./lib/main",
  "repository": "https://github.com/lumine-code/lumine",
  "license": "MIT",
  "engines": {
    "atom": "*"
  },
  "dependencies": {
    "bytes": "^3.0.0",
    "@lumine-code/etch": "https://github.com/lumine-code/etch.git#ace74599f9d6b54e9eb24ecb1e2407e9c35fcc74"
  },
  "consumedServices": {
    "status-bar": {
      "versions": {
        "^1.0.0": "consumeStatusBar"
      }
    }
  },
  "deserializers": {
    "ImageEditor": "deserialize"
  },
  "configSchema": {
    "defaultBackgroundColor": {
      "order": 1,
      "title": "Default Background Color",
      "description": "Background color shown behind transparent images.",
      "type": "string",
      "enum": [
        "white",
        "black",
        "transparent"
      ],
      "default": "transparent"
    }
  }
}
